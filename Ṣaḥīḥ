<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sahih al-Bukhari — Quiz</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400&family=Outfit:wght@400;500;600;700;800&family=Inter:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<style>
  :root{
    --primary:#146356;
    --primary-dark:#0C4338;
    --primary-light:#1F8A75;
    --primary-container:#D7EFE6;
    --on-primary:#FBF7EE;
    --gold:#BC8A23;
    --gold-light:#E2BB5C;
    --gold-pale:#F4E6BD;
    --surface:#FBF7EE;
    --surface-2:#F2EAD4;
    --surface-3:#EADFBE;
    --on-surface:#231F16;
    --on-surface-soft:#6B6354;
    --outline:#DCCFA3;
    --red:#C8473F;
    --blue:#2E6FA0;
    --yellow:#C98F1F;
    --green:#3C8757;
    --shadow-1: 0 1px 2px rgba(35,28,10,.10), 0 1px 4px rgba(35,28,10,.08);
    --shadow-2: 0 2px 4px rgba(35,28,10,.10), 0 4px 14px rgba(35,28,10,.12);
    --shadow-3: 0 6px 12px rgba(35,28,10,.14), 0 2px 4px rgba(35,28,10,.10);
    --r-card:24px;
    --r-btn:16px;
    --r-pill:100px;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:
      radial-gradient(circle at 12% 8%, rgba(188,138,35,.08), transparent 40%),
      radial-gradient(circle at 88% 92%, rgba(20,99,86,.08), transparent 40%),
      var(--surface);
    color:var(--on-surface);
    font-family:'Inter',sans-serif;
    min-height:100vh;
    -webkit-font-smoothing:antialiased;
  }
  .headline{font-family:'Outfit',sans-serif;}
  .arabic{font-family:'Amiri',serif;direction:rtl;}

  /* ---------- Full-screen shell (Zoom presentation) ---------- */
  .app-shell{
    max-width:100%;
    min-height:100vh;
    margin:0 auto;
    padding:20px 48px 32px;
    display:flex;
    flex-direction:column;
  }
  @media (max-width:768px){
    .app-shell{padding:16px 20px 24px;}
  }

  .main-col{
    min-width:0;
    flex:1;
    display:flex;
    flex-direction:column;
  }
  .screen.active{
    flex:1;
    display:flex;
    flex-direction:column;
    justify-content:center;
  }

  .top-bar{
    display:flex;align-items:center;justify-content:space-between;gap:16px;
    margin-bottom:18px;
  }
  .brand{display:flex;align-items:center;gap:10px;}
  .brand-mark{
    width:38px;height:38px;border-radius:11px;
    background:linear-gradient(155deg,var(--primary),var(--primary-dark));
    display:flex;align-items:center;justify-content:center;
    box-shadow:var(--shadow-1);
    flex:none;
  }
  .brand-mark svg{width:20px;height:20px;color:var(--on-primary);}
  .brand-text .eyebrow{
    font-size:10.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);font-weight:700;
  }
  .brand-text .title{font-family:'Outfit',sans-serif;font-weight:700;font-size:16px;color:var(--on-surface);}

  .score-chip{
    display:flex;align-items:center;gap:6px;
    background:var(--primary);
    color:var(--on-primary);
    padding:8px 14px 8px 10px;
    border-radius:var(--r-pill);
    font-weight:600;font-size:13.5px;
    box-shadow:var(--shadow-1);
    white-space:nowrap;
  }
  .score-chip svg{width:16px;height:16px;}

  .progress-track{
    width:100%;height:8px;background:var(--surface-3);border-radius:100px;overflow:hidden;margin-bottom:26px;
  }
  .progress-fill{
    height:100%;background:linear-gradient(90deg,var(--primary-light),var(--primary));
    border-radius:100px;
    transition:width .5s cubic-bezier(.4,0,.2,1);
    width:0%;
  }

  /* ---------- Screens ---------- */
  .screen{display:none;}
  .screen.active{display:block;animation:fadeUp .45s cubic-bezier(.2,.7,.2,1);}
  @keyframes fadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}

  /* Start screen */
  .hero-card{
    background:var(--surface);
    border-radius:28px;
    box-shadow:var(--shadow-2);
    padding:56px 48px;
    text-align:center;
    border:1px solid var(--outline);
    position:relative;
    overflow:hidden;
    max-width:900px;
    margin:0 auto;
    width:100%;
  }
  .hero-card::after{
    content:'';position:absolute;top:-60px;right:-60px;width:220px;height:220px;border-radius:50%;
    background:radial-gradient(circle, var(--primary-container), transparent 70%);
  }
  .hero-kicker{
    font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);font-weight:700;margin-bottom:14px;
  }
  .hero-title{
    font-family:'Outfit',sans-serif;font-weight:800;font-size:clamp(28px,4vw,42px);
    color:var(--primary-dark);line-height:1.15;margin:0 0 14px;
  }
  .hero-sub{
    font-size:16px;color:var(--on-surface-soft);max-width:480px;margin:0 auto 30px;line-height:1.6;
  }
  .hero-stats{
    display:flex;justify-content:center;gap:28px;margin-bottom:34px;flex-wrap:wrap;
  }
  .hero-stat b{display:block;font-family:'Outfit',sans-serif;font-size:24px;color:var(--primary);}
  .hero-stat span{font-size:12px;color:var(--on-surface-soft);}

  .btn{
    font-family:'Outfit',sans-serif;
    font-weight:600;font-size:15px;
    border:none;cursor:pointer;
    border-radius:var(--r-pill);
    padding:15px 32px;
    display:inline-flex;align-items:center;gap:8px;
    position:relative;overflow:hidden;
    transition:box-shadow .25s ease, transform .15s ease;
  }
  .btn-primary{background:var(--primary);color:var(--on-primary);box-shadow:var(--shadow-1);}
  .btn-primary:hover{box-shadow:var(--shadow-2);transform:translateY(-1px);}
  .btn-primary svg{width:18px;height:18px;}
  .ripple{
    position:absolute;border-radius:50%;background:rgba(255,255,255,.5);
    transform:scale(0);animation:rip .55s linear;pointer-events:none;
  }
  @keyframes rip{to{transform:scale(3.2);opacity:0;}}

  /* Question card */
  .q-card{
    background:var(--surface);
    border:1px solid var(--outline);
    border-radius:var(--r-card);
    box-shadow:var(--shadow-2);
    padding:44px 52px 40px;
    max-width:1100px;
    margin:0 auto;
    width:100%;
  }
  @media (max-width:768px){
    .q-card{padding:28px 22px 24px;}
  }
  .q-meta{display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap;}
  .q-tag{
    font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;
    background:var(--gold-pale);color:var(--gold);
    padding:5px 11px;border-radius:100px;
  }
  .q-count{font-size:12.5px;color:var(--on-surface-soft);font-weight:600;}
  .q-text{
    font-family:'Outfit',sans-serif;font-weight:700;font-size:clamp(24px,3.2vw,36px);
    line-height:1.35;color:var(--on-surface);margin:0 0 32px;
  }

  .opts{display:grid;gap:14px;}
  .opts.mcq{grid-template-columns:1fr 1fr;}
  .opts.ms{grid-template-columns:1fr 1fr;}
  @media (max-width:560px){.opts.mcq,.opts.ms{grid-template-columns:1fr;}}

  .opt{
    display:flex;align-items:center;gap:12px;
    text-align:left;
    border:none;border-radius:var(--r-btn);
    padding:18px 20px;
    font-family:'Inter',sans-serif;font-weight:600;font-size:clamp(15px,1.8vw,19px);
    color:#fff;
    cursor:pointer;position:relative;overflow:hidden;
    box-shadow:var(--shadow-1);
    transition:transform .15s ease, box-shadow .2s ease, opacity .2s ease, filter .2s ease;
  }
  .opt:hover{transform:translateY(-2px);box-shadow:var(--shadow-2);}
  .opt:active{transform:translateY(0);}
  .opt .shape{width:22px;height:22px;flex:none;fill:rgba(255,255,255,.95);}
  .opt.c-red{background:var(--red);}
  .opt.c-blue{background:var(--blue);}
  .opt.c-yellow{background:var(--yellow);}
  .opt.c-green{background:var(--green);}

  .opts.tf{grid-template-columns:1fr 1fr;}
  @media (max-width:480px){.opts.tf{grid-template-columns:1fr;}}
  .opt.tf-true{background:var(--green);}
  .opt.tf-false{background:var(--red);}
  .opt.tf-opt{justify-content:center;font-size:16px;padding:18px;}

  .opt[disabled]{cursor:default;}
  .opt.dim{opacity:.38;filter:grayscale(.3);transform:none !important;}
  .opt.is-selected{box-shadow:0 0 0 3px #fff, 0 0 0 5px var(--primary-light), var(--shadow-2);}
  .opt.is-correct{box-shadow:0 0 0 3px var(--gold), var(--shadow-2);}
  .opt.is-wrong{box-shadow:0 0 0 3px rgba(0,0,0,.25), var(--shadow-1);}
  .opt.is-correct::after, .opt.is-wrong::after{
    content:''; margin-left:auto; width:18px;height:18px;flex:none;
  }

  .feedback{
    display:flex;align-items:flex-start;gap:10px;
    margin-top:22px;padding:16px 18px;border-radius:16px;
    font-size:14px;line-height:1.55;
    animation:fadeUp .35s ease;
  }
  .feedback.good{background:var(--primary-container);color:var(--primary-dark);}
  .feedback.bad{background:#F6E2E0;color:#7E2C26;}
  .feedback svg{width:18px;height:18px;flex:none;margin-top:1px;}

  .next-row{display:flex;justify-content:flex-end;gap:12px;margin-top:24px;}
  .btn-submit{
    background:var(--gold);color:#fff;border:none;
    border-radius:var(--r-pill);padding:14px 26px;
    font-family:'Outfit',sans-serif;font-weight:600;font-size:15px;
    display:none;align-items:center;gap:8px;cursor:pointer;
    box-shadow:var(--shadow-2);position:relative;overflow:hidden;
    transition:transform .15s ease;
  }
  .btn-submit.show{display:inline-flex;animation:fadeUp .35s ease;}
  .btn-submit:hover{transform:translateY(-1px);}
  .btn-fab{
    background:var(--primary);color:var(--on-primary);border:none;
    border-radius:var(--r-pill);padding:14px 26px;
    font-family:'Outfit',sans-serif;font-weight:600;font-size:14.5px;
    display:none;align-items:center;gap:8px;cursor:pointer;
    box-shadow:var(--shadow-2);position:relative;overflow:hidden;
    transition:transform .15s ease;
  }
  .btn-fab.show{display:inline-flex;animation:fadeUp .35s ease;}
  .btn-fab:hover{transform:translateY(-1px);}
  .btn-fab svg{width:16px;height:16px;}

  /* Results screen */
  .result-card{
    background:var(--surface);border:1px solid var(--outline);
    border-radius:28px;box-shadow:var(--shadow-2);
    padding:46px 38px;text-align:center;
    max-width:900px;margin:0 auto;width:100%;
  }
  .result-icon{
    width:74px;height:74px;border-radius:50%;
    background:linear-gradient(155deg,var(--gold-light),var(--gold));
    display:flex;align-items:center;justify-content:center;margin:0 auto 22px;
    box-shadow:var(--shadow-2);
  }
  .result-icon svg{width:38px;height:38px;color:#fff;}
  .result-score{font-family:'Outfit',sans-serif;font-weight:800;font-size:46px;color:var(--primary-dark);}
  .result-score span{font-size:20px;color:var(--on-surface-soft);font-weight:600;}
  .result-msg{max-width:480px;margin:18px auto 30px;color:var(--on-surface-soft);font-size:15.5px;line-height:1.65;}
  .result-cta{
    background:var(--primary-container);border-radius:18px;padding:20px 24px;margin:0 auto 30px;max-width:480px;
    text-align:left; display:flex; gap:14px; align-items:flex-start;
  }
  .result-cta svg{width:22px;height:22px;color:var(--primary);flex:none;margin-top:2px;}
  .result-cta p{margin:0;font-size:14px;color:var(--primary-dark);line-height:1.55;}
  .result-cta b{display:block;font-family:'Outfit',sans-serif;font-size:15px;margin-bottom:3px;}
  .btn-row{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
  .btn-ghost{
    background:transparent;color:var(--primary);border:1.5px solid var(--primary);
    font-family:'Outfit',sans-serif;font-weight:600;font-size:14.5px;
    border-radius:var(--r-pill);padding:13px 26px;cursor:pointer;
  }
  .btn-ghost:hover{background:var(--primary-container);}

</style>
</head>
<body>

