      </div>
    </section>

  </div>

</div>

<script>
/* ---------------------------------------------------
   DATA
--------------------------------------------------- */
const QUESTIONS = [
  {type:'mcq', tag:'Hadith & Narrators', q:'Who narrated the hadith "Actions are judged by intentions"?', opts:['Abu Hurairah','Umar ibn al-Khattab','Aisha bint Abi Bakr','Abdullah ibn Umar'], correct:1, note:"Umar ibn al-Khattab narrated this hadith — it's placed first in Sahih al-Bukhari for a reason."},
  {type:'mcq', tag:'Hadith & Narrators', q:'Who narrated the most hadith among the Companions?', opts:['Abdullah ibn Abbas','Abdullah ibn Umar','Abu Hurairah','Anas ibn Malik'], correct:2, note:'Abu Hurairah stayed close to the Prophet ﷺ and narrated more hadith than any other Companion.'},
  {type:'mcq', tag:'Key Terms', q:'What does "isnad" refer to?', opts:['The text of the hadith','The chapter title','The chain of narrators','The explanation'], correct:2, note:'Isnad is the chain of narrators that carries a hadith back to the Prophet ﷺ.'},
  {type:'mcq', tag:'Key Terms', q:'What does "matn" refer to?', opts:['The chain of narrators','The actual text of the hadith','The compiler','The commentary'], correct:1, note:'Matn is the actual wording being narrated, as opposed to the chain that carries it.'},
  {type:'mcq', tag:'Complete the Hadith', q:'Complete the hadith: "Religion is ________."', opts:['Worship','Sincerity (Nasihah)','Prayer','Knowledge'], correct:1, note:'The Prophet ﷺ defined religion itself as sincerity — to Allah, His Book, His Messenger, and the believers.'},
  {type:'mcq', tag:'Companions', q:'Which Companion was known as "the scholar of the Ummah"?', opts:['Abdullah ibn Abbas','Abu Hurairah','Bilal ibn Rabah','Salman al-Farisi'], correct:0, note:'Ibn Abbas was so deeply learned in Qur\'an and Hadith that this title stayed with him.'},
  {type:'mcq', tag:'Complete the Hadith', q:'Complete the hadith: "Allah does not look at your appearance or wealth, but He looks at your hearts and your ________."', opts:['Knowledge','Actions','Families','Intentions'], correct:1, note:'Outward appearance carries little weight — Allah weighs the heart and the deeds.'},
  {type:'mcq', tag:'Companions', q:'Which Companion served the Prophet ﷺ for approximately ten years and narrated many hadiths?', opts:['Anas ibn Malik','Abu Hurairah','Abdullah ibn Umar','Muadh ibn Jabal'], correct:0, note:'Anas ibn Malik served the Prophet ﷺ from childhood, preserving countless details of his daily life.'},
  {type:'mcq', tag:'Sahih al-Bukhari', q:"What is the title of Imam al-Bukhari's famous collection?", opts:['Al-Muwatta','Sahih Muslim',"Al-Jami' al-Sahih",'Sunan Abi Dawud'], correct:2, note:'"Sahih al-Bukhari" is the short name — the full title is Al-Jami\' al-Sahih.'},
  {type:'mcq', tag:'Companions', q:'Which female Companion is among the greatest narrators of hadith?', opts:['Khadijah bint Khuwaylid','Aisha bint Abi Bakr','Hafsa bint Umar','Umm Salama'], correct:1, note:"Aisha (RA) is one of the most prolific and trusted narrators in all of hadith literature."},
  {type:'mcq', tag:'Sahih al-Bukhari', q:'Sahih al-Bukhari includes teachings on:', opts:['Family life','Ethics','Worship','All of the above'], correct:3, note:"Bukhari's scope is vast — worship, ethics, and family life all sit inside one collection."},
  {type:'mcq', tag:'Why We Study', q:'What is one goal of studying hadith?', opts:['Winning debates','Following the Prophet ﷺ more closely','Becoming famous','Collecting certificates'], correct:1, note:"Studying hadith isn't an academic exercise — it's a path to walking closer to the Prophet's ﷺ example."},
