</svg>

<div class="app-shell">

  <div class="main-col">
    <div class="top-bar">
      <div class="brand">
        <div class="brand-mark"><svg viewBox="0 0 24 24"><use href="#i-book"/></svg></div>
        <div class="brand-text">
          <div class="eyebrow">Takmeel · Hadith Studies</div>
                    <div class="title">Sahih al-Bukhari — Knowledge Check</div>
          <div class="title">Sahih al-Bukhari — Quiz</div>
        </div>
      </div>
      <div class="score-chip" id="scoreChip" style="display:none;">
        <svg viewBox="0 0 24 24"><use href="#i-sparkle"/></svg>
        <span id="scoreText">Score: 0</span>
      </div>
    </div>

    <div class="progress-track" id="progressTrack" style="display:none;">
      <div class="progress-fill" id="progressFill"></div>
    </div>

    <!-- START SCREEN -->
    <section class="screen active" id="screenStart">
      <div class="hero-card">
        <div class="hero-kicker">Hadith Studies Quiz</div>
        <h1 class="hero-title">Ṣaḥīḥ al-Bukhārī<br>Quiz</h1>
        <p class="hero-sub">Test your knowledge on Imam al-Bukhari, the six books of hadith, and the teachings of the Prophet ﷺ.</p>
        <div class="hero-stats">
          <div class="hero-stat"><b id="totalQuestions">44</b><span>Questions</span></div>
          <div class="hero-stat"><b>MCQ</b><span>&amp; Multi-Select</span></div>
        </div>
        <button class="btn btn-primary" id="btnStart">
          <svg viewBox="0 0 24 24"><use href="#i-lamp"/></svg>
          Start Quiz
        </button>
      </div>
    </section>

    <!-- QUIZ SCREEN -->
    <section class="screen" id="screenQuiz">
      <div class="q-card">
        <div class="q-meta">
          <span class="q-tag" id="qTag"></span>
          <span class="q-count" id="qCount"></span>
        </div>
        <h2 class="q-text" id="qText"></h2>
        <div class="opts" id="qOpts"></div>
        <div class="feedback" id="qFeedback" style="display:none;"></div>
        <div class="next-row">
          <button class="btn-submit" id="btnSubmit">Submit Answer</button>
          <button class="btn-fab" id="btnNext">Next Question <svg viewBox="0 0 24 24"><use href="#i-arrow"/></svg></button>
        </div>
      </div>
    </section>

    <!-- RESULTS SCREEN -->
    <section class="screen" id="screenResults">
      <div class="result-card">
        <div class="result-icon"><svg viewBox="0 0 24 24"><use href="#i-trophy"/></svg></div>
