];

/* ---------------------------------------------------
   STATE
--------------------------------------------------- */
let current = 0;
let score = 0;
let answered = false;
let msSelected = new Set();

const els = {
  start: document.getElementById('screenStart'),
  quiz: document.getElementById('screenQuiz'),
  results: document.getElementById('screenResults'),
  qTag: document.getElementById('qTag'),
  qCount: document.getElementById('qCount'),
  qText: document.getElementById('qText'),
  qOpts: document.getElementById('qOpts'),
  qFeedback: document.getElementById('qFeedback'),
  btnSubmit: document.getElementById('btnSubmit'),
  btnNext: document.getElementById('btnNext'),
  progressTrack: document.getElementById('progressTrack'),
  progressFill: document.getElementById('progressFill'),
  scoreChip: document.getElementById('scoreChip'),
  scoreText: document.getElementById('scoreText'),
  resultScore: document.getElementById('resultScore'),
  resultTotal: document.getElementById('resultTotal'),
  resultMsg: document.getElementById('resultMsg'),
  totalQuestions: document.getElementById('totalQuestions'),
};

const shapeIcon = {0:'i-triangle',1:'i-diamond',2:'i-circle',3:'i-square'};
const shapeClass = {0:'c-red',1:'c-blue',2:'c-yellow',3:'c-green'};

function setsEqual(a, b){
  if(a.size !== b.size) return false;
  for(const v of a) if(!b.has(v)) return false;
  return true;
}

function addRipple(btn, evt){
  const r = document.createElement('span');
  r.className = 'ripple';
  const rect = btn.getBoundingClientRect();
  const size = Math.max(rect.width, rect.height);
  r.style.width = r.style.height = size + 'px';
  r.style.left = (evt.clientX - rect.left - size/2) + 'px';
  r.style.top = (evt.clientY - rect.top - size/2) + 'px';
  btn.appendChild(r);
  setTimeout(()=>r.remove(), 600);
}

function showScreen(name){
  [els.start, els.quiz, els.results].forEach(s=>s.classList.remove('active'));
  ({start:els.start, quiz:els.quiz, results:els.results}[name]).classList.add('active');
}

function renderQuestion(){
  answered = false;
  msSelected = new Set();
  const data = QUESTIONS[current];
  els.qTag.textContent = data.tag;
  els.qCount.textContent = `Question ${current+1} of ${QUESTIONS.length}`;
  els.qText.textContent = data.q;
  els.qFeedback.style.display = 'none';
  els.btnNext.classList.remove('show');
  els.btnSubmit.classList.remove('show');
  els.progressFill.style.width = `${(current/QUESTIONS.length)*100}%`;

  els.qOpts.innerHTML = '';
  const layout = data.type === 'tf' ? 'tf' : (data.type === 'ms' ? 'ms' : 'mcq');
  els.qOpts.className = 'opts ' + layout;

  const opts = data.type === 'tf' ? ['True','False'] : data.opts;

  opts.forEach((text, idx)=>{
    const btn = document.createElement('button');
    btn.className = 'opt';
    if(data.type === 'tf'){
      btn.classList.add(idx===0 ? 'tf-true' : 'tf-false', 'tf-opt');
      btn.innerHTML = `<svg class="shape" viewBox="0 0 24 24"><use href="#${idx===0?'i-check':'i-cross'}"/></svg> ${text}`;
      btn.addEventListener('click', (e)=>{
        addRipple(btn, e);
        selectAnswer(idx, data);
      });
    } else if(data.type === 'ms'){
      btn.classList.add(shapeClass[idx % 4]);
      btn.innerHTML = `<svg class="shape" viewBox="0 0 24 24"><use href="#${shapeIcon[idx % 4]}"/></svg> ${text}`;
      btn.addEventListener('click', (e)=>{
        if(answered) return;
        addRipple(btn, e);
        if(msSelected.has(idx)){
          msSelected.delete(idx);
          btn.classList.remove('is-selected');
        } else {
          msSelected.add(idx);
          btn.classList.add('is-selected');
        }
        els.btnSubmit.classList.toggle('show', msSelected.size > 0);
      });
    } else {
      btn.classList.add(shapeClass[idx]);
      btn.innerHTML = `<svg class="shape" viewBox="0 0 24 24"><use href="#${shapeIcon[idx]}"/></svg> ${text}`;
      btn.addEventListener('click', (e)=>{
        addRipple(btn, e);
        selectAnswer(idx, data);
      });
    }
    els.qOpts.appendChild(btn);
  });

  if(data.type === 'ms'){
    els.btnSubmit.classList.remove('show');
  }
}

function revealAnswer(data, isCorrect, selectedIdx){
  const correctSet = Array.isArray(data.correct) ? new Set(data.correct) : new Set([data.correct]);
  const allOpts = [...els.qOpts.children];

  allOpts.forEach((btn, i)=>{
    btn.disabled = true;
    if(correctSet.has(i)){
      btn.classList.add('is-correct');
    } else {
      btn.classList.add('dim');
      if(selectedIdx !== null && (Array.isArray(selectedIdx) ? selectedIdx.includes(i) : i === selectedIdx)){
        btn.classList.add('is-wrong');
      }
    }
  });

  if(isCorrect) score++;

  els.qFeedback.style.display = 'flex';
  els.qFeedback.className = 'feedback ' + (isCorrect ? 'good' : 'bad');
  els.qFeedback.innerHTML = `<svg viewBox="0 0 24 24"><use href="#${isCorrect?'i-good':'i-bad'}"/></svg><div>${isCorrect ? 'Correct! ' : 'Not quite — '}${data.note}</div>`;

  els.scoreChip.style.display = 'flex';
  els.scoreText.textContent = `Score: ${score}`;

  els.btnSubmit.classList.remove('show');
  els.btnNext.classList.add('show');
  els.btnNext.innerHTML = (current === QUESTIONS.length-1)
    ? `See Results <svg viewBox="0 0 24 24"><use href="#i-arrow"/></svg>`
    : `Next Question <svg viewBox="0 0 24 24"><use href="#i-arrow"/></svg>`;
}

function selectAnswer(idx, data){
  if(answered) return;
  answered = true;
  const isCorrect = idx === data.correct;
  revealAnswer(data, isCorrect, idx);
}

function submitMultiSelect(data){
  if(answered || msSelected.size === 0) return;
  answered = true;
  const correctSet = new Set(data.correct);
  const isCorrect = setsEqual(msSelected, correctSet);
  revealAnswer(data, isCorrect, [...msSelected]);
}

function nextQuestion(){
  if(current < QUESTIONS.length - 1){
    current++;
    renderQuestion();
  } else {
    finishQuiz();
  }
}

function finishQuiz(){
  els.progressFill.style.width = '100%';
  els.resultScore.textContent = score;
  els.resultTotal.textContent = ` / ${QUESTIONS.length} correct`;
  const pct = score / QUESTIONS.length;
  let msg;
  if(pct >= 0.85){
    msg = "Excellent work — you have a strong grasp of Sahih al-Bukhari and the teachings of the Prophet ﷺ.";
  } else if(pct >= 0.5){
    msg = "Good effort! Review the questions you missed and keep learning.";
  } else {
    msg = "Keep studying — every question is a chance to learn more about the Sunnah.";
  }
  els.resultMsg.textContent = msg;
  showScreen('results');
  els.progressTrack.style.display = 'none';
}

function restartQuiz(){
  current = 0; score = 0; answered = false;
  els.scoreChip.style.display = 'none';
  els.progressTrack.style.display = 'block';
  showScreen('start');
}

document.getElementById('btnStart').addEventListener('click', (e)=>{
  addRipple(e.currentTarget, e);
  current = 0; score = 0;
  els.progressTrack.style.display = 'block';
  showScreen('quiz');
  renderQuestion();
});

els.btnSubmit.addEventListener('click', (e)=>{
  addRipple(e.currentTarget, e);
  submitMultiSelect(QUESTIONS[current]);
});
els.btnNext.addEventListener('click', (e)=>{ addRipple(e.currentTarget, e); nextQuestion(); });
document.getElementById('btnRestart').addEventListener('click', (e)=>{ addRipple(e.currentTarget, e); restartQuiz(); });

els.totalQuestions.textContent = QUESTIONS.length;
</script>
